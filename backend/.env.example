# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/vaultshare
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/vaultshare
MONGO_URI=mongodb://127.0.0.1:27017/vaultshare

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ─── AES Encryption ────────────────────────────────────────────
# Must be exactly 32 characters for AES-256
AES_SECRET=vaultshare_super_secret_key_32ch

# ─── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ─── Frontend (for share links) ────────────────────────────────
FRONTEND_URL=http://localhost:5173
